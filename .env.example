# =============================================================
# Finance Project - Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=financedb
DB_USERNAME=finance_user
DB_PASSWORD=

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Market Data Providers ---
# Note: FMP (Financial Modeling Prep) has been removed.
# Yahoo Finance (yfinance) is used as the primary provider - no key required.

# Tiingo - free EOD price fallback (sign up at https://api.tiingo.com/)
TIINGO_API_KEY=

# Finnhub - news, analyst recommendations, sentiment
FINNHUB_API_KEY=

# --- MongoDB (news documents, raw API responses, GPT analysis logs) ---
MONGO_URI=mongodb://localhost:27017/financedb

# --- Azure OpenAI ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# --- FastAPI data-service URL (Spring agent-analysis client) ---
DATA_SERVICE_URL=http://localhost:8000

# --- CI/CD secrets (GitHub -> Settings -> Secrets -> Actions) ---
# DB_PASSWORD - test DB icin
# JWT_SECRET - test icin herhangi 32+ char string
