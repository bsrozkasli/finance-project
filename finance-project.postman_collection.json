      "name": "Backend REST APIs (Spring Boot)",
      "item": [
        {
          "name": "Add Asset Batch",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"symbols\": [\"AAPL\", \"MSFT\", \"GOOGL\", \"TSLA\"]\n}"
            },
            "url": {
              "raw": "{{backend_url}}/api/v1/assets/batch",
              "host": [
                "{{backend_url}}"
              ],
              "path": [
                "api",
                "v1",
                "assets",
                "batch"
              ]
            },
            "description": "Batch persists new ticker symbols in the database, fetching metadata from Financial Modeling Prep (FMP) or falling back to a default stock model."
          },
          "response": []
        },
