        {
          "name": "Get Price History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{backend_url}}/api/v1/prices/AAPL/history?interval=1d&range=1mo",
              "host": [
                "{{backend_url}}"
              ],
              "path": [
                "api",
                "v1",
                "prices",
                "AAPL",
                "history"
              ],
              "query": [
                {
                  "key": "interval",
                  "value": "1d",
                  "description": "Candle interval (e.g. 1h, 1d, 1wk)"
                },
                {
                  "key": "range",
                  "value": "1mo",
                  "description": "Lookback range (e.g. 5d, 1mo, 3mo, 6mo, 1y)"
                }
              ]
            },
            "description": "Returns OHLCV history. Checks database first, falls back on FastAPI data-service to fetch and persist on demand."
          },
          "response": []
        },
        {
          "name": "Get Agent Analysis",
          "request": {
